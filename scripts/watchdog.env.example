# JIANCHA Dashboard — Watchdog & Production Environment
# ─────────────────────────────────────────────────────
# Copy to scripts/watchdog.env and fill in real values:
#   cp scripts/watchdog.env.example scripts/watchdog.env
#
# DO NOT commit watchdog.env (already gitignored)

# ─── Alert Webhook ─────────────────────────────────
# Format: slack | discord | teams
ALERT_FORMAT=teams

# Webhook URL (one of):
# - Slack:    https://hooks.slack.com/services/T.../B.../...
# - Discord:  https://discord.com/api/webhooks/.../...
# - Teams:    https://prod-XX.southeastasia.logic.azure.com/.../triggers/...  (Workflows)
#             or https://XXX.webhook.office.com/...  (legacy Connector — deprecated)
ALERT_WEBHOOK=

# ─── Watchdog thresholds ───────────────────────────
# Alert if no sync has happened in this many hours (default 8)
STALE_HOURS=8

# Chrome remote-debugging port (must be open for orchestrator)
CHROME_PORT=9222
