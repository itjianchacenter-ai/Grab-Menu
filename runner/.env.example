# Master password for encrypting/decrypting vault.enc
# Use a long random string. Keep this file gitignored.
VAULT_PASSWORD=change-me-to-a-long-random-string

# Local sync server (extension POSTs here)
SYNC_SERVER=http://localhost:8765

# Headless mode for runner (false recommended — extensions need headed)
HEADLESS=false

# Min/max delay between branches in seconds
DELAY_MIN=20
DELAY_MAX=60

# Max branches per run (0 = no limit). Useful for testing
BRANCHES_LIMIT=0

# Retry attempts per branch
RETRY_ATTEMPTS=3
