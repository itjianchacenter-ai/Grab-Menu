{
  "manifest_version": 3,
  "name": "Grab Menu Checker",
  "version": "0.2.0",
  "description": "ดึงข้อมูลเมนูจาก Grab Merchant Portal มาแสดงพร้อม Dashboard + log การเปลี่ยนสถานะ",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://merchant.grab.com/*",
    "https://*.grabtaxi.com/*",
    "https://portal.grab.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://merchant.grab.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://merchant.grab.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Grab Menu Checker"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
